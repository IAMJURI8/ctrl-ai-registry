    {
      "id": "a0006a53-3dc8-4087-9a0e-4f5c73f3a52f",
      "name": "Flatten Best Practices",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -128,
        416
      ],
      "parameters": {
        "jsCode": "const blocks = $input.all().map(i => i.json);\nconst out = [];\n\nfunction rtToMd(rt) {\n  if (!Array.isArray(rt)) return '';\n  return rt.map(r => {\n    let t = r.plain_text !== undefined ? r.plain_text : (r.text && r.text.content) || '';\n    const a = r.annotations || {};\n    if (a.code) t = '`' + t + '`';\n    if (a.bold) t = '**' + t + '**';\n    if (a.italic) t = '*' + t + '*';\n    return t;\n  }).join('');\n}\n\nfor (const b of blocks) {\n  const type = b.type;\n  if (!type) continue;\n  const d = b[type] || {};\n  const t = rtToMd(d.rich_text || []);\n  switch (type) {\n    case 'paragraph': if (t) { out.push(t); out.push(''); } break;\n    case 'heading_1': out.push(''); out.push('# ' + t); out.push(''); break;\n    case 'heading_2': out.push(''); out.push('## ' + t); out.push(''); break;\n    case 'heading_3': out.push(''); out.push('### ' + t); out.push(''); break;\n    case 'bulleted_list_item': out.push('- ' + t); break;\n    case 'numbered_list_item': out.push('1. ' + t); break;\n    case 'quote': out.push('> ' + t); out.push(''); break;\n    case 'callout': { const emoji = (d.icon && d.icon.emoji) || ''; out.push('> ' + (emoji ? emoji + ' ' : '') + t); out.push(''); break; }\n    case 'divider': out.push(''); out.push('---'); out.push(''); break;\n    case 'code': out.push('```' + (d.language || '')); out.push(t); out.push('```'); out.push(''); break;\n    case 'to_do': out.push('- [ ] ' + t); break;\n    case 'toggle': out.push('- ' + t); break;\n    default: if (t) { out.push(t); out.push(''); }\n  }\n}\n\nconst markdown = out.join('\\n').trim();\nreturn [{ json: { markdown, blockCount: blocks.length } }];"
      }
    },
