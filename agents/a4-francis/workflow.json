      "parameters": {
        "jsCode": "const msg = $input.first().json;\nconst chatId = String(\n  msg.message?.chat?.id ||\n  msg.channel_post?.chat?.id ||\n  ''\n);\nconst text = (\n  msg.message?.text ||\n  msg.channel_post?.text ||\n  ''\n).trim();\nconst lower = text.toLowerCase();\nconst isNew = lower === '/new';\nconst isPostCommand = lower === '/post';\n\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.sessions) staticData.sessions = {};\nif (!staticData.pending) staticData.pending = {};\n\nif (isNew) {\n  const id = Date.now().toString(36) + Math.random().toString(36).slice(2);\n  staticData.sessions[chatId] = id;\n  staticData.pending[chatId] = null;\n} else if (!staticData.sessions[chatId]) {\n  const id = Date.now().toString(36) + Math.random().toString(36).slice(2);\n  staticData.sessions[chatId] = id;\n}\n\nconst pendingPost = staticData.pending[chatId] || null;\nconst isPost = isPostCommand && !!pendingPost;\n\nreturn [{\n  json: {\n    chatId,\n    text,\n    isNew,\n    isPost,\n    sessionId: staticData.sessions[chatId],\n    pendingPost\n  }\n}];"
      },
