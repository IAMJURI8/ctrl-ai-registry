      "parameters": {
        "jsCode": "const agentOutput = $input.first().json.response || $input.first().json.text || $input.first().json.output || '';\nconst chatId = $('Extract Context').item.json.chatId;\n\nconst postMatch = agentOutput.match(/<post>([\\s\\S]*?)<\\/post>/);\nconst postContent = postMatch ? postMatch[1].trim() : null;\n\nlet textContent = agentOutput;\nif (postMatch) textContent = textContent.replace(postMatch[0], '').trim();\n\nif (postContent) {\n  const staticData = $getWorkflowStaticData('global');\n  if (!staticData.pending) staticData.pending = {};\n  staticData.pending[chatId] = postContent;\n}\n\nreturn [{\n  json: {\n    chatId,\n    textContent,\n    postContent,\n    hasPost: !!postContent,\n    fullOutput: agentOutput\n  }\n}];"
      },
