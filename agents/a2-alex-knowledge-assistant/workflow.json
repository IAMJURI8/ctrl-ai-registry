    {
      "id": "a1000000-0000-0000-0000-00000000000b",
      "name": "Alex Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 2.2,
      "position": [464, 320],
      "parameters": {
