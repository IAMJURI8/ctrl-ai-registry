    {
      "id": "a1000000-0000-0000-0000-000000000002",
      "name": "Extract Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -736,
        320
      ],
      "parameters": {
        "jsCode": "const msg = $input.first().json;\nconst message = msg.message || msg.channel_post || {};\nconst chatId = String(message.chat?.id || '');\nconst text = (message.text || message.caption || '').trim();\nconst voice = message.voice;\n\nlet inputType = 'text';\nlet voiceFileId = '';\nlet url = '';\n\nif (voice && voice.file_id) {\n  inputType = 'voice';\n  voiceFileId = voice.file_id;\n} else {\n  const urlMatch = text.match(/https?:\\/\\/\\S+/);\n  if (urlMatch && (text === urlMatch[0] || text.length < urlMatch[0].length + 80)) {\n    inputType = 'url';\n    url = urlMatch[0];\n  }\n}\n\nreturn [{ json: { chatId, inputType, text, voiceFileId, url } }];"
      }
    },
    {
      "id": "a1000000-0000-0000-0000-000000000003",
      "name": "Route Input Type",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [
        -512,
        320
      ],
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "loose"
                },
                "conditions": [
                  {
                    "id": "cond-text",
                    "leftValue": "={{ $json.inputType }}",
                    "rightValue": "text",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "text"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "loose"
