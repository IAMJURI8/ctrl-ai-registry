    {
      "id": "c0000000-0000-0000-0000-000000000001",
      "name": "queryKB",
      "type": "@n8n/n8n-nodes-langchain.toolHttpRequest",
      "typeVersion": 1.1,
      "position": [
        720,
        528
      ],
      "parameters": {
        "toolDescription": "Search the Alex Knowledge Base. Returns pages matching filters, newest first by default. Each result has `id` (page ID for follow-up ops) and `properties`. The IDs of returned results will stay in the agent's working memory for later updateEntry/archiveEntry calls.",
        "method": "POST",
        "url": "https://api.notion.com/v1/databases/50f36c97-1e2d-45fc-8483-c8a223523077/query",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "notionApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Notion-Version",
              "value": "2022-06-28"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($fromAI('body', 'Notion databases/query POST body as a JSON object. Keys: filter (optional Notion filter object \u2014 supports compound and/or plus property filters on select/multi_select/title properties), sorts (optional, default created_time desc), page_size (optional, default 10, max 25). Example: { \"filter\": { \"property\": \"GTD Status\", \"select\": { \"equals\": \"Inbox\" } }, \"page_size\": 10 }', 'json')) }}"
      },
      "credentials": {
        "notionApi": {
          "id": "brvlRm4prk1LZUyR",
          "name": "Notion account"
        }
      }
    },
