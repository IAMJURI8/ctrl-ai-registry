      "id": "a1000000-0000-0000-0000-000000000005",
      "name": "Whisper Transcribe",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [-48, 432],
      "parameters": {
        "resource": "audio",
