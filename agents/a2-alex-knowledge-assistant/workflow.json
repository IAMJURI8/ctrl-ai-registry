    },
    {
      "id": "a1000000-0000-0000-0000-000000000006",
      "name": "Fetch URL",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-272, 624],
      "parameters": {
        "method": "GET",
        "url": "={{ $('Extract Context').item.json.url }}",
        "options": {
          "redirect": { "redirect": { "followRedirects": true, "maxRedirects": 5 } },
          "response": { "response": { "responseFormat": "text" } },
          "timeout": 15000
        }
      }
    },
    {
      "id": "a1000000-0000-0000-0000-000000000007",
      "name": "Extract Meta",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-48, 624],
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst html = String(item.data || item.body || '');\nconst url = $('Extract Context').item.json.url;\n\nconst titleMatch = html.match(/<title[^>]*>([\\s\\S]*?)<\\/title>/i);\nconst descMatch =\n  html.match(/<meta[^>]*name=[\"']description[\"'][^>]*content=[\"']([\\s\\S]*?)[\"']/i) ||\n  html.match(/<meta[^>]*content=[\"']([\\s\\S]*?)[\"'][^>]*name=[\"']description[\"']/i) ||\n  html.match(/<meta[^>]*property=[\"']og:description[\"'][^>]*content=[\"']([\\s\\S]*?)[\"']/i);\n\nfunction clean(s) {\n  return s.replace(/\\s+/g, ' ').trim();\n}\n\nreturn [{\n  json: {\n    url,\n    title: titleMatch ? clean(titleMatch[1]).slice(0, 200) : '',\n    description: descMatch ? clean(descMatch[1]).slice(0, 500) : ''\n  }\n}];"
      }
    },
    {
      "id": "a1000000-0000-0000-0000-000000000008",
      "name": "Build Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [240, 320],
      "parameters": {
        "jsCode": "const ctx = $('Extract Context').item.json;\nconst incoming = $input.first().json;\nlet userMessage = '';\n\nif (ctx.inputType === 'text') {\n  userMessage = ctx.text;\n} else if (ctx.inputType === 'voice') {\n  const transcript = incoming.text || incoming.transcript || '';\n  userMessage = `Voice transcript: ${transcript}`;\n} else if (ctx.inputType === 'url') {\n  const meta = incoming;\n  userMessage = `${meta.url} | title: ${meta.title || 'unknown'} | meta: ${meta.description || 'none'}`;\n  if (ctx.text && ctx.text !== meta.url && !ctx.text.startsWith('http')) {\n    userMessage = `${ctx.text}\\n\\n${userMessage}`;\n  }\n}\n\nreturn [{ json: { chatId: ctx.chatId, userMessage } }];"
      }
    },
    {
      "id": "a1000000-0000-0000-0000-000000000009",
      "name": "Anthropic Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatAnthropic",
      "typeVersion": 1.3,
      "position": [400, 528],
      "parameters": {
        "model": {
          "__rl": true,
          "mode": "list",
          "value": "claude-sonnet-4-5-20250929",
