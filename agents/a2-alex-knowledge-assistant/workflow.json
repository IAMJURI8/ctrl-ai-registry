          "systemMessage": "Loaded from agents/a2-alex-knowledge-assistant/system-prompt.xml at workflow import time. See that file for the canonical version."
        }
      }
    },
    {
      "id": "a1000000-0000-0000-0000-00000000000c",
      "name": "Parse Classification",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [704, 320],
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst output = item.output || item.text || item.response || '';\nconst chatId = $('Extract Context').item.json.chatId;\n\nconst jsonMatch = output.match(/```json\\s*([\\s\\S]*?)```/);\nlet classification = null;\nlet isClarification = false;\nlet clarificationText = '';\n\nif (jsonMatch) {\n  try {\n    classification = JSON.parse(jsonMatch[1].trim());\n  } catch (e) {\n    isClarification = true;\n    clarificationText = output;\n  }\n} else {\n  isClarification = true;\n  clarificationText = output.trim();\n}\n\nlet tagsCsv = '';\nif (classification && Array.isArray(classification.tags)) {\n  tagsCsv = classification.tags.join(',');\n}\n\nreturn [{\n  json: {\n    chatId,\n    isClarification,\n    clarificationText,\n    classification,\n    name: classification?.name || '',\n    type: classification?.type || '',\n    gtdStatus: classification?.gtdStatus || 'Inbox',\n    source: classification?.source || 'Other',\n    tagsCsv,\n    notes: classification?.notes || '',\n    summary: classification?.summary || 'Saved.'\n  }\n}];"
      }
    },
    {
      "id": "a1000000-0000-0000-0000-00000000000d",
      "name": "Is Clarification?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [928, 320],
      "parameters": {
