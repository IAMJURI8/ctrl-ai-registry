  "nodes": [
    {
      "id": "a1000000-0000-0000-0000-000000000001",
      "name": "Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [
        -960,
        320
      ],
      "parameters": {
        "updates": [
          "message"
        ],
        "additionalFields": {}
      },
      "webhookId": "a2-alex-telegram-trigger",
      "credentials": {
        "telegramApi": {
          "id": "XiPoK10AazY77yJ3",
          "name": "Telegram Alex"
